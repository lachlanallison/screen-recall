{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenRecall",
  "version": "0.1.0",
  "identifier": "dev.screenrecall.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter desktop dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm --filter desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "ScreenRecall",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "",
    "shortDescription": "Private local screen recall",
    "longDescription": "A private, local-first screen recall desktop app. Records and indexes your screen so you can search and chat with your history using a local LLM."
  }
}
